# ═══════════════════════════════
# Anthropic (for planning calls)
# ═══════════════════════════════
ANTHROPIC_API_KEY=

# ═══════════════════════════════
# Agent auth
# Shared secret — Comet sends this
# as Bearer token on every request
# ═══════════════════════════════
AGENT_SECRET=

# ═══════════════════════════════
# Server
# ═══════════════════════════════
PORT=3001

# Public-facing base URL (used in agent.json identity card)
# e.g. https://comet-playwright.fly.dev
PUBLIC_URL=
