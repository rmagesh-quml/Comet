# ═══════════════════════════════
# Anthropic (for planning calls)
# ═══════════════════════════════
ANTHROPIC_API_KEY=

# ═══════════════════════════════
# Agent auth
# Shared secret — Comet sends this
# as Bearer token on every request
# ═══════════════════════════════
AGENT_SECRET=

# ═══════════════════════════════
# PostgreSQL (for session storage)
# Use the same DATABASE_URL as the
# main Comet app — shares the DB.
# Leave blank to disable sessions
# (tasks will start unauthenticated)
# ═══════════════════════════════
DATABASE_URL=postgresql://localhost:5432/comet

# ═══════════════════════════════
# Server
# ═══════════════════════════════
PORT=3001

# Public-facing base URL (used in agent.json identity card)
# e.g. https://comet-playwright.fly.dev
PUBLIC_URL=

# ═══════════════════════════════
# Task timeout
# Default: 240000 (4 min)
# Max allowed per-task: 600000 (10 min)
# Increase for Banner/Canvas on slow days
# ═══════════════════════════════
DEFAULT_TASK_TIMEOUT_MS=240000
