# ═══════════════════════════════
# Linq (primary iMessage provider)
# Leave blank to use Twilio only
# ═══════════════════════════════
LINQ_API_TOKEN=
LINQ_PHONE_NUMBER=
LINQ_WEBHOOK_URL=

# ═══════════════════════════════
# Twilio (fallback + Android/SMS)
# Required — used when Linq is
# blank or recipient not on iMessage
# ═══════════════════════════════
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ═══════════════════════════════
# Anthropic
# ═══════════════════════════════
ANTHROPIC_API_KEY=

# ═══════════════════════════════
# Agent
# ═══════════════════════════════
AGENT_NAME=Comet
PORT=3000
DAILY_MESSAGE_LIMIT=30
GLOBAL_DAILY_LIMIT=500
DATABASE_URL=postgresql://localhost:5432/comet

# ═══════════════════════════════
# Canvas LMS
# ═══════════════════════════════
CANVAS_BASE_URL=https://canvas.vt.edu

# ═══════════════════════════════
# Microsoft Graph (Outlook/Calendar)
# Register app at https://portal.azure.com
# Redirect URI must match MICROSOFT_REDIRECT_URI
# ═══════════════════════════════
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=
WEBHOOK_BASE_URL=
WEBHOOK_SECRET=

# ═══════════════════════════════
# Google (Gmail + Calendar)
# Register app at https://console.cloud.google.com
# Enable Gmail API and Google Calendar API
# ═══════════════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_PUBSUB_TOPIC=

# ═══════════════════════════════
# Spotify
# Register app at https://developer.spotify.com/dashboard
# ═══════════════════════════════
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ═══════════════════════════════
# OpenWeatherMap
# Get API key at https://openweathermap.org/api
# ═══════════════════════════════
OPENWEATHERMAP_API_KEY=

# ═══════════════════════════════
# Discord digest / iOS Shortcut sync
# ═══════════════════════════════
HEALTH_SYNC_SECRET=

# ═══════════════════════════════
# Blacksburg Transit (GTFS)
# Static feed: zip URL from BT developer portal
# Real-time: protobuf feed URLs
# ═══════════════════════════════
BT_GTFS_URL=
BT_REALTIME_TRIP_UPDATES_URL=
BT_REALTIME_VEHICLE_POSITIONS_URL=

# ═══════════════════════════════
# Qdrant (semantic memory)
# Cloud: https://cloud.qdrant.io
# Self-hosted: http://localhost:6333
# ═══════════════════════════════
QDRANT_URL=
QDRANT_API_KEY=

# ═══════════════════════════════
# OpenAI (embeddings only)
# ═══════════════════════════════
OPENAI_API_KEY=
